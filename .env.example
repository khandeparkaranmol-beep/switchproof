# Copy this file to ".env" and fill in your keys. The .env file is gitignored — it will
# never be committed. SwitchProof loads it automatically on every run.

# The FRONTIER model (the reference / incumbent). Get a key: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# The OPEN model (the cheap candidate), served by Groq. Get a key: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Optional overrides (defaults shown). Prices are $/1M tokens — set your real rates.
# SP_FRONTIER_MODEL=claude-sonnet-5
# SP_OPEN_MODEL=llama-3.1-8b-instant
# SP_FRONTIER_PRICE_IN=3.00
# SP_FRONTIER_PRICE_OUT=15.00
# SP_OPEN_PRICE_IN=0.05
# SP_OPEN_PRICE_OUT=0.08
# SP_MONTHLY_CALLS=1000000
